{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-deck.local/schemas/signal-input.schema.json",
  "title": "signal-deck ingestion contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "brief",
    "sources",
    "signals",
    "synthesis",
    "editorialDecisions"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "inputId", "createdAt", "language"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "inputId": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "objective", "audience", "timeHorizon"],
      "properties": {
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "timeHorizon": {
          "type": "string",
          "minLength": 1
        },
        "deliverable": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "title", "sourceType", "publisher"],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "sourceType": {
            "type": "string",
            "minLength": 1
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signalId",
          "statement",
          "category",
          "priority",
          "sourceIds",
          "evidence",
          "implications"
        ],
        "properties": {
          "signalId": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "sourceIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "implications": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "counterpoints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "synthesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workingThesis", "supportingThemes", "openQuestions"],
      "properties": {
        "workingThesis": {
          "type": "string",
          "minLength": 1
        },
        "supportingThemes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "openQuestions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "missingInformation": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "editorialDecisions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heroFrame",
        "topLineThesis",
        "radarOrder",
        "deepDiveSignalIds",
        "marketMapFrames",
        "watchlistSeeds"
      ],
      "properties": {
        "heroFrame": {
          "type": "string",
          "minLength": 1
        },
        "topLineThesis": {
          "type": "string",
          "minLength": 1
        },
        "radarOrder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "deepDiveSignalIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "marketMapFrames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "watchlistSeeds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
