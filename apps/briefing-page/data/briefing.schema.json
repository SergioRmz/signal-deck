{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-deck.local/schemas/briefing.schema.json",
  "title": "signal-deck briefing contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "hero",
    "topLine",
    "radar",
    "deepDives",
    "marketMap",
    "watchlist"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "briefingId", "editionDate"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "briefingId": {
          "type": "string",
          "minLength": 1
        },
        "editionDate": {
          "type": "string",
          "minLength": 1
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "lede"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "lede": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "topLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "radar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "text"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "deepDives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "marketMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "text"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "watchlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
