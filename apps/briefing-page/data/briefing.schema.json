{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-deck.local/schemas/briefing.schema.json",
  "title": "signal-deck briefing contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "hero",
    "topLine",
    "radar",
    "deepDives",
    "marketMap",
    "watchlist"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "briefingId", "editionDate"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "briefingId": {
          "type": "string",
          "minLength": 1
        },
        "editionDate": {
          "type": "string",
          "minLength": 1
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "readerContext": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "roles": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "interests": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "desiredUpgrade": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "lede"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "lede": {
          "type": "string",
          "minLength": 1
        },
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "thesis": {
          "type": "string",
          "minLength": 1
        },
        "tension": {
          "type": "string",
          "minLength": 1
        },
        "promise": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "topLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "stakes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "radar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "text"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "type": "string",
                "enum": ["supports-thesis", "complicates-thesis", "contradiction", "monitor"]
              }
            }
          }
        }
      }
    },
    "deepDives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "mechanism": {
                "type": "string",
                "minLength": 1
              },
              "claim": {
                "type": "string",
                "minLength": 1
              },
              "explanation": {
                "type": "string",
                "minLength": 1
              },
              "implication": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "marketMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "text"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "powerShift": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "readerTranslation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "headline", "body"],
            "properties": {
              "role": {
                "type": "string",
                "minLength": 1
              },
              "headline": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "weight": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          }
        }
      }
    },
    "reusableLesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "pattern", "takeaway"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "applyWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "takeaway": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "watchlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["confirmation", "invalidation", "metric", "question"]
              }
            }
          }
        }
      }
    }
  }
}
